# Project Helix API Keys
# You only need to set the keys for the models you intend to use. LiteLLM handles the routing.

# OpenAI (ChatGPT, gpt-4o, gpt-4o-mini)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (Claude 3.5 Sonnet, Opus)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DeepSeek (DeepSeek Coder, DeepSeek Chat)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Qwen (via DashScope / Aliyun)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# OpenRouter (Access to Qwen, Claude, DeepSeek, Llama via one API key)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Other Providers (Groq, Together, etc.)
# GROQ_API_KEY=your_groq_api_key_here
# TOGETHERAI_API_KEY=your_together_api_key_here

# Local Models via Ollama
 OLLAMA_API_BASE=http://localhost:11434
